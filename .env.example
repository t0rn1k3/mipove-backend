PORT=5000
# Atlas SRV: mongodb+srv://user:pass@cluster.mongodb.net/mipove
# Atlas Standard (bypasses SRV DNS): mongodb://user:pass@host1:27017,host2:27017,host3:27017/mipove?ssl=true&replicaSet=atlas-xxx-shard-0&authSource=admin
MONGODB_URI=mongodb://localhost:27017/mipove
# Optional fallback DB name when URI has no /database segment
MONGO_DB_NAME=mipove
NODE_ENV=development
JWT_SECRET=your-super-secret-key-change-in-production
# Access token settings
JWT_EXPIRE=15m
# Optional auth cookie max-age override in seconds (fallback: JWT_EXPIRE)
# AUTH_COOKIE_MAX_AGE_SECONDS=900
# Backward-compat alias for auth cookie max-age:
# COOKIE_MAX_AGE_SECONDS=900

# Refresh token settings
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRE=7d
# Optional refresh cookie max-age override in seconds
# REFRESH_COOKIE_MAX_AGE_SECONDS=604800
# Rotate refresh token on /api/auth/refresh (true/false)
ROTATE_REFRESH_TOKEN=true

# Admin registration - if set, require this in body when registering admin
ADMIN_SECRET=your-admin-secret-change-in-production

# CORS: frontend origin (dev: http://localhost:3000, prod: your deployed URL)
FRONTEND_URL=http://localhost:3000
