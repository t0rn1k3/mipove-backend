PORT=5000
# Atlas SRV: mongodb+srv://user:pass@cluster.mongodb.net/mipove
# Atlas Standard (bypasses SRV DNS): mongodb://user:pass@host1:27017,host2:27017,host3:27017/mipove?ssl=true&replicaSet=atlas-xxx-shard-0&authSource=admin
MONGODB_URI=mongodb://localhost:27017/mipove
# Optional fallback DB name when URI has no /database segment
MONGO_DB_NAME=mipove
NODE_ENV=development
JWT_SECRET=your-super-secret-key-change-in-production
# Access token settings
JWT_EXPIRE=15m
# Optional auth cookie max-age override in seconds (fallback: JWT_EXPIRE)
# AUTH_COOKIE_MAX_AGE_SECONDS=900
# Backward-compat alias for auth cookie max-age:
# COOKIE_MAX_AGE_SECONDS=900

# Refresh token settings
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRE=7d
# Optional refresh cookie max-age override in seconds
# REFRESH_COOKIE_MAX_AGE_SECONDS=604800
# Rotate refresh token on /api/auth/refresh (true/false)
ROTATE_REFRESH_TOKEN=true

# Admin registration - if set, require this in body when registering admin
ADMIN_SECRET=your-admin-secret-change-in-production

# CORS: frontend origin (dev: http://localhost:3000, prod: your deployed URL)
FRONTEND_URL=http://localhost:3000

# Credits — registration bonus on POST /api/auth/masters/register
CREDIT_REGISTRATION_BONUS=30
# Per-action spend cost (POST /api/credits/spend); non-negative integers, defaults 1 / 5 if unset
CREDIT_COST_VIEW_CONTACT=1
CREDIT_COST_FEATURE_GALLERY=5

# Payment provider (BOG Payments API is implemented; legacy IPAY_* names are read as aliases)
# IPAY_MERCHANT_ID — not sent in the current ecommerce order payload (reserved for future/alternate gateways)
IPAY_MERCHANT_ID=your_merchant_id
# Bearer token for create-order: use IPAY_SECRET_KEY or PAYMENT_BOG_IPAY_TOKEN (either is accepted)
IPAY_SECRET_KEY=your_secret_key
# Create-session URL: use IPAY_API_URL or PAYMENT_BOG_IPAY_URL (either is accepted)
IPAY_API_URL=https://api.bog.ge/payments/v1/ecommerce/orders
# Aliases (optional if IPAY_* above are set)
PAYMENT_BOG_IPAY_URL=
PAYMENT_BOG_IPAY_TOKEN=
# Server-to-server payment callback (must be HTTPS; BOG POSTs JSON to POST /api/webhooks/payment)
PAYMENT_CALLBACK_URL=https://your-api-domain.com/api/webhooks/payment
# Browser redirect after checkout (success/fail)
PAYMENT_RETURN_URL=https://your-frontend-domain.com/credits/success
# BOG Callback-Signature RSA public key (optional; defaults to documented BOG key)
# PAYMENT_BOG_CALLBACK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Optional: X-Payment-Hmac hex (SHA-256 HMAC of raw body) instead of BOG RSA
# PAYMENT_WEBHOOK_HMAC_SECRET=

# Backblaze B2 (S3-compatible) — required for profile, portfolio, order images, and POST /api/upload
# B2_REGION must match the region in B2_ENDPOINT (e.g. eu-central-003)
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=
# Optional: public base URL if using a CDN or custom domain (default: endpoint/bucket)
# B2_PUBLIC_BASE_URL=
