PORT=5000
MONGODB_URI=mongodb://localhost:27017/mipove
NODE_ENV=development
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE=30d

# Admin registration - if set, require this in body when registering admin
ADMIN_SECRET=your-admin-secret-change-in-production

# CORS: frontend origin (dev: http://localhost:3000, prod: your deployed URL)
FRONTEND_URL=http://localhost:3000
