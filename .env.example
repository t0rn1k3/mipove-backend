PORT=5000
# Use "mipove" database - NOT "test". For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/mipove
MONGODB_URI=mongodb://localhost:27017/mipove
NODE_ENV=development
JWT_SECRET=your-super-secret-key-change-in-production
# JWT_EXPIRE: token + cookie lifetime (e.g. 15m, 1h, 7d). Use 7d for longer sessions with HttpOnly cookies.
JWT_EXPIRE=7d
# Optional: override cookie Max-Age in seconds (e.g. 604800 = 7 days)
# COOKIE_MAX_AGE_SECONDS=604800

# Admin registration - if set, require this in body when registering admin
ADMIN_SECRET=your-admin-secret-change-in-production

# CORS: frontend origin (dev: http://localhost:3000, prod: your deployed URL)
FRONTEND_URL=http://localhost:3000
